numOfWords=0
numOfLetters=0
numOfDigits=0

text=input("Enter a text of num, letters, and digits: ")

for x in text:
 if x>='a'and x<='z' or x>='A' and x<='Z':
        numOfLetters+=1
 elif x>='0' and x<='9':
         numOfDigits+=1    
 elif x==' ':
     numOfWords+=1
print("Number of letters: ", numOfLetters)
print("Number of digits: ", numOfDigits)
print("Number of words: ", numOfWords+1)
